rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Users ───
    // Chaque user ne peut lire/écrire que son propre document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── Workspaces ───
    match /workspaces/{workspaceId} {
      // Création : l'utilisateur doit être authentifié et se déclarer owner + membre
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.members;

      // Lecture : membres OU utilisateur avec invitation en attente
      allow read: if request.auth != null && (
        request.auth.uid in resource.data.members
        || (resource.data.pendingInvites != null
            && request.auth.token.email in resource.data.pendingInvites)
      );

      // Mise à jour : membres OU utilisateur avec invitation en attente (pour se joindre)
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.members
        || (resource.data.pendingInvites != null
            && request.auth.token.email in resource.data.pendingInvites)
      );

      // Suppression : uniquement le propriétaire
      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }

    // ─── Share links ───
    match /shareLinks/{token} {
      // Tout le monde peut lire un lien (pour voir l'info avant de rejoindre)
      allow read: if request.auth != null;

      // Seul un membre du workspace peut créer un lien
      allow create: if request.auth != null;

      // Le créateur ou le owner du workspace peut modifier (révoquer)
      allow update: if request.auth != null
        && resource.data.createdBy == request.auth.uid;

      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;
    }

    // ─── Invitations ───
    // Collection séparée pour la découverte cross-user
    match /invites/{inviteId} {
      // Un user peut lire les invitations adressées à son email
      allow read: if request.auth != null
        && resource.data.email == request.auth.token.email;

      // Tout user authentifié peut créer une invitation
      allow create: if request.auth != null;

      // L'invité peut supprimer l'invitation (après acceptation)
      allow delete: if request.auth != null
        && resource.data.email == request.auth.token.email;
    }
  }
}

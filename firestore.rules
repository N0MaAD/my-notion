rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(ws) {
      return request.auth.uid == ws.data.ownerId;
    }
    function isMember(ws) {
      return request.auth.uid in ws.data.members;
    }
    function strOk(val, maxLen) {
      return val is string && val.size() > 0 && val.size() <= maxLen;
    }

    // ─── Users ───
    match /users/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    // ─── Workspaces ───
    match /workspaces/{workspaceId} {
      // Création : owner + membre, champs validés
      allow create: if isAuth()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.members
        && strOk(request.resource.data.name, 200)
        && request.resource.data.members is list
        && request.resource.data.members.size() <= 100;

      // Lecture : membres OU invité en attente
      allow read: if isAuth() && (
        request.auth.uid in resource.data.members
        || (resource.data.pendingInvites != null
            && request.auth.token.email in resource.data.pendingInvites)
      );

      // Mise à jour : membres avec restrictions, OU invité (champs limités)
      allow update: if isAuth() && (
        // Membres existants
        (request.auth.uid in resource.data.members
          // Personne ne peut changer le ownerId sauf le owner
          && (request.resource.data.ownerId == resource.data.ownerId
              || resource.data.ownerId == request.auth.uid)
          // Le nom doit rester valide
          && strOk(request.resource.data.name, 200)
          // Les membres restent une liste bornée
          && request.resource.data.members is list
          && request.resource.data.members.size() <= 100
        )
        // Invité en attente : peut seulement se joindre
        || (resource.data.pendingInvites != null
            && request.auth.token.email in resource.data.pendingInvites
            && request.resource.data.name == resource.data.name
            && request.resource.data.ownerId == resource.data.ownerId
        )
      );

      // Suppression : uniquement le propriétaire
      allow delete: if isAuth()
        && resource.data.ownerId == request.auth.uid;
    }

    // ─── Share links ───
    match /shareLinks/{token} {
      allow read: if isAuth();

      allow create: if isAuth()
        && exists(/databases/$(database)/documents/workspaces/$(request.resource.data.workspaceId))
        && request.auth.uid in get(/databases/$(database)/documents/workspaces/$(request.resource.data.workspaceId)).data.members
        && request.resource.data.workspaceId is string
        && request.resource.data.createdBy == request.auth.uid;

      allow update: if isAuth()
        && resource.data.createdBy == request.auth.uid;

      allow delete: if isAuth()
        && resource.data.createdBy == request.auth.uid;
    }

    // ─── Push tokens ───
    match /pushTokens/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    // ─── Config (read-only for clients) ───
    match /config/{docId} {
      allow read: if isAuth();
    }

    // ─── Workspace Chat ───
    match /workspaceChats/{wsId}/messages/{msgId} {
      allow read: if isAuth()
        && exists(/databases/$(database)/documents/workspaces/$(wsId))
        && request.auth.uid in get(/databases/$(database)/documents/workspaces/$(wsId)).data.members;

      allow create: if isAuth()
        && exists(/databases/$(database)/documents/workspaces/$(wsId))
        && request.auth.uid in get(/databases/$(database)/documents/workspaces/$(wsId)).data.members
        && request.resource.data.userId == request.auth.uid
        && strOk(request.resource.data.text, 5000);

      allow update, delete: if isAuth()
        && exists(/databases/$(database)/documents/workspaces/$(wsId))
        && request.auth.uid in get(/databases/$(database)/documents/workspaces/$(wsId)).data.members
        && resource.data.userId == request.auth.uid;
    }

    // ─── Invitations ───
    match /invites/{inviteId} {
      allow read: if isAuth()
        && resource.data.email == request.auth.token.email;

      allow create: if isAuth()
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 320
        && request.resource.data.workspaceId is string
        && exists(/databases/$(database)/documents/workspaces/$(request.resource.data.workspaceId))
        && request.auth.uid in get(/databases/$(database)/documents/workspaces/$(request.resource.data.workspaceId)).data.members;

      allow delete: if isAuth()
        && resource.data.email == request.auth.token.email;
    }
  }
}
